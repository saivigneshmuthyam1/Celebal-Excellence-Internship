# Example secrets file for local or hosted Streamlit deployments.
# Copy this to .streamlit/secrets.toml and fill in your own values.
# Do not commit the real secrets.toml file.

GITHUB_TOKEN = "ghp_your_token_here"
OPENAI_API_KEY = "sk-your_key_here"
GOOGLE_API_KEY = "your_google_key_here"
GOOGLE_API_KEY_APP = "your_google_key_here"
GOOGLE_API_KEY_EVAL = "your_google_key_here"
GROQ_API_KEY = "gsk_your_key_here"
GROQ_API_KEY_EVAL = "gsk_your_eval_key_here"

# PatchContext environment variables
# Copy this file to .env and fill in your keys for local development.
# For deployment (Streamlit Cloud, Render, Railway, etc.), prefer platform secrets
# instead of committing real values.

# GitHub Personal Access Token (no scopes needed for public repos)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# OpenAI API Key
# Create at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_key_here

# Google AI API Key (optional, used by some evaluation paths)
GOOGLE_API_KEY=your_google_key_here
GOOGLE_API_KEY_APP=your_google_key_here
GOOGLE_API_KEY_EVAL=your_google_key_here

# Groq API Key (for LLM generation and RAGAs eval)
# Create at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here
GROQ_API_KEY_EVAL=gsk_your_eval_key_here
